; Copy this file to  credentials.ini  (gitignored) and fill in your values.
; PlatformIO merges this same-named section's build_flags into [env:tab5].
;
; - KIT_SSID / KIT_PASS: the kit's own 2.4 GHz WiFi that the Tab5 joins to reach
;   the RuView server (the CardputerZero, or a dev box running the RuView Docker).
; - RUVIEW_HOST: override the server IP here (e.g. your dev box running
;   `docker run -p 3000:3000 ruvnet/wifi-densepose`).
;
; Keep the  '"..."'  quoting exactly.

[env:tab5]
build_flags =
    -DKIT_SSID='"your_kit_ssid"'
    -DKIT_PASS='"your_kit_password"'
    -DRUVIEW_HOST='"192.168.1.20"'
    -DRUVIEW_PORT=3000
