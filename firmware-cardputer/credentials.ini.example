; Copy this file to  credentials.ini  (gitignored) and fill in your home WiFi.
; PlatformIO merges this same-named section's build_flags into the main env, so
; HOME_SSID / HOME_PASS become compile-time defines the firmware falls back to
; (saved Preferences creds, if any, still take priority at runtime).
;
; The single/double quoting matters — keep the  '"..."'  form exactly.

[env:cardputer-radar-csi]
build_flags =
    -DHOME_SSID='"your_wifi_ssid"'
    -DHOME_PASS='"your_wifi_password"'
